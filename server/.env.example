# HHTTPS Server v0.4.1 — Environment Configuration
#
# Copy this file to .env and fill in your values.
# Never commit .env to git (it's in .gitignore).

# ─── Application ─────────────────────────────────────────────────────────
PORT=3000
RP_ID=hhttps.org
ORIGIN=https://hhttps.org
BASE_URL=https://hhttps.org

# ─── PostgreSQL ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hhttps
DB_USER=hhttps
DB_PASSWORD=                # set this — install-pg.sh generates one

# ─── SMTP (for email verification) ───────────────────────────────────────
# Optional but recommended. Without these, email-verified methods won't work.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=info@example.com
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ─── Token TTLs (seconds, optional — defaults below) ─────────────────────
# ACCESS_TTL=3600           # 1 hour
# REFRESH_TTL=604800        # 7 days

# ─── Rate limits (optional — defaults are sensible) ──────────────────────
# RATE_LIMIT_GLOBAL=300     # requests per minute per IP
# RATE_LIMIT_WEBAUTHN=20    # per 15 minutes
# RATE_LIMIT_EMAIL=5        # per hour
