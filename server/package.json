  },
  "dependencies": {
    "@simplewebauthn/server": "^9.0.3",
    "cors":                   "^2.8.5",
    "express":                "^4.18.2",
    "express-rate-limit":     "^7.3.1",
    "helmet":                 "^7.1.0",
    "jsonwebtoken":           "^9.0.2",
    "nodemailer":             "^6.9.9",
    "pg":                     "^8.11.5",
    "uuid":                   "^9.0.0"
  }
}
